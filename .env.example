VITE_API_URL=http://localhost:8001
CODECOV_TOKEN=your-codecov-token
# Canonical site URL used for SEO (canonical link, Open Graph, sitemap, robots).
# Overrides `siteUrl` in src/config/seo.ts. No trailing slash.
VITE_SITE_URL=https://www.matthieu-freitag.com

# ============================================================================
# Analytics (umami) — see src/config/analytics.ts and docs/analytics.md
# ============================================================================
# Privacy-friendly, cookieless analytics (no consent banner needed).
# Everything below is OPTIONAL: leave VITE_UMAMI_HOST / VITE_UMAMI_WEBSITE_ID
# empty and no tracking script is injected at all. A blank value here always
# falls back to the default in src/config/analytics.ts.
#
# Two ways to deploy — pick ONE (details + nginx recipe in docs/analytics.md):
#
#   A) Direct (simplest)
#      The browser loads the script from, and posts events straight to, your
#      umami host. Set VITE_UMAMI_HOST to the umami URL and leave
#      VITE_UMAMI_HOST_URL empty. Downside: the umami host is third-party, so
#      ad-blockers with tracker lists can block it.
#
#   B) First-party proxy (recommended — dodges ad-blockers)
#      The browser only ever talks to YOUR OWN domain; your reverse proxy
#      (nginx/Traefik) forwards two paths to the umami container:
#          /<scriptName>   ->  umami  (serves the tracker script)
#          /api/send       ->  umami  (receives the events)
#      Because both requests are same-origin, blockers that rely on
#      third-party host lists don't see them. To enable this mode, point BOTH
#      VITE_UMAMI_HOST and VITE_UMAMI_HOST_URL at your own site's domain (the
#      umami host is never exposed to the browser). Renaming the script (e.g.
#      stats.js) helps evade generic "umami/script.js" filters.

# Master switch. Set to 'false' to disable analytics even when the ids below
# are filled in (handy to keep prod config but turn it off in staging/dev).
VITE_UMAMI_ENABLED=true

# Origin the browser loads the tracker <script src> from (no trailing slash).
#   A) Direct       -> your umami host, e.g. https://analytics.example.com
#   B) First-party  -> your OWN site domain, e.g. https://www.example.com
# Empty = analytics off.
VITE_UMAMI_HOST=

# Website UUID from the umami dashboard (Settings -> Websites -> your site).
# Empty = analytics off.
VITE_UMAMI_WEBSITE_ID=

# Tracker script filename. MUST match umami's TRACKER_SCRIPT_NAME env
# (e.g. TRACKER_SCRIPT_NAME=stats -> stats.js); a mismatch is a 404 = no
# tracking. In first-party mode this is also the path your proxy forwards to
# umami. Rename it (stats.js, t.js…) to reduce ad-blocker matches. Default: script.js.
VITE_UMAMI_SCRIPT_NAME=script.js

# data-host-url: the origin the tracker POSTs events to (it appends /api/send).
#   A) Direct       -> leave EMPTY (events go to the script's origin = VITE_UMAMI_HOST).
#   B) First-party  -> your OWN site domain (same value as VITE_UMAMI_HOST),
#                      so events hit /api/send on your domain and get proxied to umami.
# No trailing slash.
VITE_UMAMI_HOST_URL=